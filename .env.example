# ============================================================
# ENVIRONMENT VARIABLES — mise en place
# ============================================================
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to git — it contains secret keys!
#
# HOW TO GET THESE VALUES:
#
# SUPABASE:
#   1. Go to https://supabase.com and create a free project
#   2. Go to Project Settings → API
#   3. Copy "Project URL" → VITE_SUPABASE_URL
#   4. Copy "anon public" key → VITE_SUPABASE_ANON_KEY
#
# ANTHROPIC (for URL import feature):
#   1. Go to https://console.anthropic.com
#   2. Create an API key
#   3. Paste it below — but NOTE: in production, this should live
#      in a server-side function (Vercel serverless), not the frontend.
#      For now we'll use it client-side for prototyping only.
# ============================================================

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
