.env.local
.env.*.local
.env.example

# Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Session review docs — local only
docs/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
